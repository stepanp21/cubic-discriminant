Cell[BoxData[
 RowBox[{"unitBinormal", "=", 
  RowBox[{"Simplify", "[", 
   RowBox[{
    RowBox[{"Cross", "[", 
     RowBox[{"unitTangent", ",", "unitNormal"}], "]"}], ",", 
