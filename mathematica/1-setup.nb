Cell[BoxData[
 RowBox[{"torsion", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"-", 
     RowBox[{"dunitBinormal", "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], "/", 
    RowBox[{"unitNormal", "[", 
     RowBox[{"[", "1", "]"}], "]"}]}], "/", "speed"}]}]], "Input",
