     RowBox[{"Axes", "->", "False"}], ",", 
     RowBox[{"PlotPoints", "->", "40"}]}], "\[IndentingNewLine]", "]"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"ParametricPlot3D", "[", 
    RowBox[{"f", ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", 
       RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
     RowBox[{"PlotStyle", "->", "Green"}]}], "]"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"ParametricPlot3D", "[", 
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"r", "/.", 
        RowBox[{"t", "->", "i"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", 
         RowBox[{"-", "8"}], ",", "8"}], "}"}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"v", ",", 
