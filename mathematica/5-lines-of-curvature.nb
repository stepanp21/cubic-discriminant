fd83aa658d18"],

Cell[BoxData[
 RowBox[{"Show", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"ParametricPlot3D", "[", 
    RowBox[{"r", ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", 
       RowBox[{"-", "8"}], ",", "8"}], "}"}], ",", 
