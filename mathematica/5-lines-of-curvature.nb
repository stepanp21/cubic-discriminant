 CellLabel->
  "In[611]:=",ExpressionUUID->"f2909173-417c-4b17-a7de-88c98bc74857"],

Cell["\<\
We can then solve the DE giving orthogonal trajectories to the rulings on the \
surface to get v in terms of t along the other set of lines of curvature.\
\>", "Text",
 CellChangeTimes->{{3.981017170896163*^9, 
  3.981017247444654*^9}},ExpressionUUID->"fbae4ad1-b07c-41bf-a8a2-\
970e69ed8b91"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ClearAll", "[", "b", "]"}], ";"}]], "Input",
 CellChangeTimes->{{3.981896383823366*^9, 3.981896386942415*^9}},
 CellLabel->
  "In[356]:=",ExpressionUUID->"ea49cb60-e10d-4102-a8cd-01c1a8bb886e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"vLOC", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"b", "-", "t", "-", 
      RowBox[{
       RowBox[{"t", "^", "3"}], "/", "3"}]}], ")"}], "/", 
    RowBox[{"(", 
     RowBox[{"1", "+", 
      RowBox[{"t", "^", "2"}]}], ")"}]}]}], ";"}]], "Code",
 CellChangeTimes->{{3.981017253413433*^9, 3.981017308111094*^9}, {
  3.9810174931811666`*^9, 3.98101749372892*^9}},
 CellLabel->
  "In[133]:=",ExpressionUUID->"b11e3db7-9c58-460f-9ea6-686c1d1a18f3"],

Cell["Confirming that these are orthogonal to the rulings.", "Text",
 CellChangeTimes->{{3.9810173499155893`*^9, 
  3.9810173705754547`*^9}},ExpressionUUID->"339b7bf8-11b9-4b91-a1b7-\
8e1a3f48f24e"],

Cell[BoxData[
 RowBox[{"Simplify", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"D", "[", 
     RowBox[{"r", ",", "v"}], "]"}], ".", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{"r", ",", "t"}], "]"}], "+", 
      RowBox[{
       RowBox[{"D", "[", 
        RowBox[{"r", ",", "v"}], "]"}], "*", 
       RowBox[{"D", "[", 
        RowBox[{"vLOC", ",", "t"}], "]"}]}]}], ")"}]}], "/.", 
   RowBox[{"v", "->", "vLOC"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.9810174048146467`*^9, 3.981017478356401*^9}, {
  3.981017515173213*^9, 3.9810175330960703`*^9}},
 CellLabel->
  "In[618]:=",ExpressionUUID->"a3ec9add-e6d5-409a-9f28-b47709f0fd93"],

Cell["\<\
Useful for other calculations will be finding the value of b where these \
lines of curvature meet the twisted cubic; that is, solving for b when vLOC=0 \
for a given t.\
\>", "Text",
 CellChangeTimes->{{3.981947338684051*^9, 3.981947400267151*^9}, {
  3.981948227716064*^9, 
  3.981948236130878*^9}},ExpressionUUID->"c0167b71-d46b-4f3a-9b62-\
7935ead09de6"],

