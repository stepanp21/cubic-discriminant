Cell[BoxData[
 RowBox[{"Manipulate", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"ParametricPlot3D", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"fff", "[", "a", "]"}], "[", "t", "]"}], "/.", 
        "paramfInterp"}], ")"}], "+", 
      RowBox[{"u", "*", 
       RowBox[{"(", 
