 CellLabel->
  "In[119]:=",ExpressionUUID->"2c95d9ac-df6c-4c5b-9e7c-7535aa1df1b1"],

Cell[BoxData[
 RowBox[{"f3", "=", 
  RowBox[{"alpha", "*", 
   RowBox[{"Exp", "[", "lambda2Real", "]"}], "*", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"Cos", "[", "lambda2Im", "]"}], "*", "v2Im"}], "+", 
     RowBox[{
      RowBox[{"Sin", "[", "lambda2Im", "]"}], "*", "v2Real"}]}], 
    ")"}]}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.980442425710793*^9, 3.980442508361723*^9}, 
