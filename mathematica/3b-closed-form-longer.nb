 CellLabel->
  "In[120]:=",ExpressionUUID->"5c146137-dba1-4487-9a38-34573c8648de"],

Cell[BoxData[
 RowBox[{"scalarAssign", "=", 
  RowBox[{"Simplify", "[", 
   RowBox[{
    RowBox[{"Solve", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"c1", "*", "f1"}], "+", 
           RowBox[{"c2", "*", "f2"}], "+", 
           RowBox[{"c3", "*", "f3"}]}], ")"}], "/.", 
         RowBox[{"t", "->", "0"}]}], ")"}], "==", 
       RowBox[{"{", 
        RowBox[{"1", ",", "0", ",", "0"}], "}"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"c1", ",", "c2", ",", "c3"}], "}"}]}], "]"}], ",", 
    RowBox[{"Assumptions", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"t", "\[Element]", "Reals"}], ",", 
       RowBox[{"alpha", "\[Element]", "Reals"}]}], "}"}]}]}], 
   "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.980442588432548*^9, 3.980442653002717*^9}, {
  3.980442839059009*^9, 3.980442892621117*^9}},
 CellLabel->
  "In[121]:=",ExpressionUUID->"97d2fcde-1d58-41d4-9ba8-70d28d22ec2f"],

Cell[BoxData[
 RowBox[{"tangCF", "=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"c1", "*", "f1"}], "+", 
      RowBox[{"c2", "*", "f2"}], "+", 
      RowBox[{"c3", "*", "f3"}]}], "/.", "scalarAssign"}], ")"}], "[", 
   RowBox[{"[", "1", "]"}], "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.9804412663621283`*^9, 3.98044127878025*^9}, {
  3.980442918584753*^9, 3.9804429444335957`*^9}, {3.980443033639661*^9, 
  3.980443039455803*^9}},
 CellLabel->
  "In[122]:=",ExpressionUUID->"865948e1-3fe3-441b-8868-3aadefd570ec"],

Cell[BoxData[
 RowBox[{"paramfInterp", "=", 
  RowBox[{"ParametricNDSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"fff", "'"}], "[", "t", "]"}], "==", 
       RowBox[{"tangCF", "*", "speed"}]}], ",", 
      RowBox[{
       RowBox[{"fff", "[", "0", "]"}], "==", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", "0"}], "}"}]}]}], "}"}], ",", "fff", ",", 
    
    RowBox[{"{", 
     RowBox[{"t", ",", 
      RowBox[{"-", "20"}], ",", "20"}], "}"}], ",", 
    RowBox[{"{", "alpha", "}"}]}], "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.980507894317224*^9, 3.980507969543898*^9}, {
