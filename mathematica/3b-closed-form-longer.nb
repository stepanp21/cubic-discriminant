  "In[123]:=",ExpressionUUID->"c23a9407-43ea-4b6b-9f06-42fb098c68f8"],

Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"ParametricPlot3D", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"fff", "[", "alpha", "]"}], "[", "t", "]"}], "/.", 
      "paramfInterp"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", 
       RowBox[{"-", "3"}], ",", "3"}], "}"}]}], "]"}], ",", 
   RowBox[{"{", 
