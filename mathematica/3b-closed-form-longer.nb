130e291cb864"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"BVar", "=", 
   RowBox[{"Integrate", "[", 
    RowBox[{"AVar", ",", "t"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"MatrixForm", "[", "BVar", "]"}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.980440264849688*^9, 3.980440316399577*^9}},
 CellLabel->
  "In[111]:=",ExpressionUUID->"ba63f707-da68-4acb-b06d-8a4ef8e5dd08"],

Cell[BoxData[
 RowBox[{"es", "=", 
  RowBox[{"Simplify", "[", 
   RowBox[{
    RowBox[{"Eigensystem", "[", "BVar", "]"}], ",", 
    RowBox[{"Assumptions", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"t", "\[Element]", "Reals"}], ",", 
       RowBox[{"alpha", "\[Element]", "Reals"}]}], "}"}]}]}], 
   "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.9804403592017603`*^9, 3.980440379174581*^9}, {
  3.98044141470578*^9, 3.980441439121141*^9}, {3.9804417180428057`*^9, 
  3.9804417224557543`*^9}},
 CellLabel->
  "In[113]:=",ExpressionUUID->"ad0fd64c-9617-4198-aaab-2ed811bfe6c7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"{", 
   RowBox[{"lambda1", ",", "v1"}], "}"}], "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"es", "[", 
     RowBox[{"[", 
      RowBox[{"1", ",", "1"}], "]"}], "]"}], ",", 
    RowBox[{"es", "[", 
     RowBox[{"[", 
      RowBox[{"2", ",", "1"}], "]"}], "]"}]}], "}"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.980441238551399*^9, 3.9804412930455227`*^9}},
 CellLabel->
  "In[114]:=",ExpressionUUID->"a54e82b5-3ff0-4e5f-942c-e40b5cafa83a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"{", 
   RowBox[{"lambda2", ",", "v2"}], "}"}], "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"es", "[", 
     RowBox[{"[", 
      RowBox[{"1", ",", "2"}], "]"}], "]"}], ",", 
    RowBox[{"es", "[", 
     RowBox[{"[", 
      RowBox[{"2", ",", "2"}], "]"}], "]"}]}], "}"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.98044176763336*^9, 3.98044178745158*^9}, {
  3.9804418859656897`*^9, 3.980441887331218*^9}},
 CellLabel->
  "In[115]:=",ExpressionUUID->"779c4af5-9a75-42c5-8ac7-2b3a1610f577"],

Cell[BoxData[""], "Input",
 CellChangeTimes->{{3.980441789818726*^9, 
  3.980441796933353*^9}},ExpressionUUID->"9a12f39a-2141-4082-996a-\
91524172099e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"{", 
   RowBox[{"lambda2Real", ",", "v2Real"}], "}"}], "=", 
  RowBox[{"Simplify", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Re", "[", 
       RowBox[{"es", "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "2"}], "]"}], "]"}], "]"}], ",", 
      RowBox[{"Re", "[", 
       RowBox[{"es", "[", 
        RowBox[{"[", 
         RowBox[{"2", ",", "2"}], "]"}], "]"}], "]"}]}], "}"}], ",", 
    RowBox[{"Assumptions", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"t", "\[Element]", "Reals"}], ",", 
       RowBox[{"alpha", "\[Element]", "Reals"}], ",", 
       RowBox[{"alpha", "!=", "0"}]}], "}"}]}]}], "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.980441299135168*^9, 3.9804414084948893`*^9}, {
  3.980441448890972*^9, 3.980441532169479*^9}},
 CellLabel->
  "In[116]:=",ExpressionUUID->"72567b01-78bc-4f0e-a14b-e61af479a2cd"],

Cell[BoxData[
 RowBox[{
  RowBox[{"{", 
   RowBox[{"lambda2Im", ",", "v2Im"}], "}"}], "=", 
  RowBox[{"Simplify", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Im", "[", 
       RowBox[{"es", "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "2"}], "]"}], "]"}], "]"}], ",", 
      RowBox[{"Im", "[", 
       RowBox[{"es", "[", 
        RowBox[{"[", 
         RowBox[{"2", ",", "2"}], "]"}], "]"}], "]"}]}], "}"}], ",", 
    RowBox[{"Assumptions", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"t", "\[Element]", "Reals"}], ",", 
       RowBox[{"alpha", "\[Element]", "Reals"}], ",", 
       RowBox[{"alpha", "!=", "0"}]}], "}"}]}]}], "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.980441299135168*^9, 3.9804414084948893`*^9}, {
  3.980441448890972*^9, 3.980441554277952*^9}},
 CellLabel->
  "In[117]:=",ExpressionUUID->"e31f92eb-16e5-4eeb-97a5-9ab52e1e2632"],

Cell[BoxData[
 RowBox[{"f1", "=", 
  RowBox[{
   RowBox[{"Exp", "[", 
    RowBox[{"lambda1", "*", "t"}], "]"}], "*", "v1"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.980441565836668*^9, 3.980441587221808*^9}},
 CellLabel->
  "In[118]:=",ExpressionUUID->"2be659f7-abfe-44d2-9dc4-e7efc64111c9"],

Cell[BoxData[
 RowBox[{"f2", "=", 
  RowBox[{"alpha", "*", 
   RowBox[{"Exp", "[", "lambda2Real", "]"}], "*", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"Cos", "[", "lambda2Im", "]"}], "*", "v2Real"}], "-", 
     RowBox[{
      RowBox[{"Sin", "[", "lambda2Im", "]"}], "*", "v2Im"}]}], 
    ")"}]}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.980442199004231*^9, 3.980442274486486*^9}, {
  3.980442324290328*^9, 3.980442324729129*^9}, {3.980442401294656*^9, 
