Cell[CellGroupData[{

Cell["Visualizing the unfolding dynamically", "Section",
 CellChangeTimes->{{3.979011065156358*^9, 
  3.979011091242985*^9}},ExpressionUUID->"1a6e60f3-2437-459a-8a24-\
203ce3cb5851"],

Cell["\<\
The next step is to figure out what the surface looks like as it unfolds \
dynamically. My idea is to fix the curvature function and linearly \
interpolate the torsion function from 0 to its value along the twisted cubic. \
Then for each value along the interpolation, we recover the curve from the \
curvature and torsion to get a curve homotopy. And for each of these curves, \
we draw the tangent developable.\
\>", "Text",
 CellChangeTimes->{{3.9790110941389847`*^9, 
  3.979011224680732*^9}},ExpressionUUID->"faa679a0-47ff-4eeb-bee1-\
f53f33d501da"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"AVar", "=", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0", ",", "curvature", ",", "0"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "curvature"}], ",", "0", ",", 
        RowBox[{"alpha", "*", "torsion"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", 
        RowBox[{
         RowBox[{"-", "alpha"}], "*", "torsion"}], ",", "0"}], "}"}]}], "}"}],
     "*", "speed"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"MatrixForm", "[", "AVar", "]"}]}], "Code",
 CellChangeTimes->{{3.9790330705381107`*^9, 3.9790330963232727`*^9}, {
  3.9790346301932096`*^9, 3.979034633055594*^9}, {3.979034729774571*^9, 
  3.979034737119783*^9}},
 CellLabel->
  "In[107]:=",ExpressionUUID->"33a89bf0-4ebe-4aee-9dea-0f44210c680d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"This", " ", "causes", " ", "errors"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"tang", "[", 
           RowBox[{"t", ",", "alpha"}], "]"}], ",", "t"}], "]"}], "==", 
        RowBox[{"AVar", ".", 
         RowBox[{"tang", "[", 
          RowBox[{"t", ",", "alpha"}], "]"}]}]}], ",", 
       RowBox[{
        RowBox[{"tang", "[", 
         RowBox[{"0", ",", "alpha"}], "]"}], "==", 
        RowBox[{"{", 
         RowBox[{"1", ",", "0", ",", "0"}], "}"}]}]}], "}"}], ",", "tang", ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", 
       RowBox[{"-", "5"}], ",", "5"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"alpha", ",", "0", ",", "1"}], "}"}]}], "]"}], 
   "*)"}]}]], "Input",
 CellChangeTimes->{{3.979034650326415*^9, 3.979034652089795*^9}, {
  3.9790347465093403`*^9, 3.979034749603743*^9}, {3.979034789489071*^9, 
  3.979034823684589*^9}, {3.979034987469202*^9, 3.9790350002321243`*^9}},
 CellLabel->
  "In[281]:=",ExpressionUUID->"735ddbf8-3e5e-4266-8815-9701b2db998c"],

