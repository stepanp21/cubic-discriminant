Cell["\<\
Our goal here will be to make a manipulable of the developable surface \
unfolding from the plane to the correct tangent developable.\
\>", "Text",
 CellChangeTimes->{{3.9804394283772697`*^9, 
  3.9804394672756767`*^9}},ExpressionUUID->"0ee19fe6-ffb0-4b43-bbb6-\
230340b7699e"],

Cell[CellGroupData[{

Cell["Recovering curve from curvature and torsion", "Section",
 CellChangeTimes->{{3.97903342296841*^9, 
  3.979033430955699*^9}},ExpressionUUID->"e0eaab83-89a6-4a1c-af7b-\
4a45693d7787"],

Cell["\<\
As proof of concept, let\[CloseCurlyQuote]s recover the twisted cubic from \
the curvature and torsion.\
\>", "Text",
 CellChangeTimes->{{3.97903459182273*^9, 
  3.979034610810738*^9}},ExpressionUUID->"76601677-c73a-4ebc-800f-\
5eef601188ed"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"A", "=", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0", ",", "curvature", ",", "0"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "curvature"}], ",", "0", ",", "torsion"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", 
        RowBox[{"-", "torsion"}], ",", "0"}], "}"}]}], "}"}], "*", 
    "speed"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"MatrixForm", "[", "A", "]"}]}], "Code",
 CellChangeTimes->{{3.9790330705381107`*^9, 3.9790330963232727`*^9}},
 CellLabel->
  "In[103]:=",ExpressionUUID->"9c2ec9ac-a8b9-456d-a03f-43656ab35500"],

Cell[BoxData[
 RowBox[{"tangInterp", "=", 
  RowBox[{"NDSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"tang", "'"}], "[", "t", "]"}], "==", 
       RowBox[{"A", ".", 
        RowBox[{"tang", "[", "t", "]"}]}]}], ",", 
      RowBox[{
       RowBox[{"tang", "[", "0", "]"}], "==", 
       RowBox[{"{", 
        RowBox[{"1", ",", "0", ",", "0"}], "}"}]}]}], "}"}], ",", "tang", ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", 
      RowBox[{"-", "10"}], ",", "10"}], "}"}]}], "]"}]}]], "Code",
 CellChangeTimes->{{3.979033443883667*^9, 3.9790335059806957`*^9}, {
  3.979033629919258*^9, 3.979033630051672*^9}, {3.979033682735667*^9, 
  3.9790336902091103`*^9}, {3.9790338211217003`*^9, 3.97903382268876*^9}},
 CellLabel->
  "In[105]:=",ExpressionUUID->"393f1623-487a-4626-ae91-dfbaaab9ba36"],

Cell[BoxData[
 RowBox[{"ffInterp", "=", 
  RowBox[{"NDSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"ff", "[", "0", "]"}], "==", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", "0"}], "}"}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"ff", "'"}], "[", "t", "]"}], "==", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"speed", "*", 
          RowBox[{"tang", "[", "t", "]"}]}], "/.", 
         RowBox[{"tangInterp", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ")"}]}]}], "}"}], ",", "ff", ",", 
    
    RowBox[{"{", 
     RowBox[{"t", ",", 
      RowBox[{"-", "10"}], ",", "10"}], "}"}]}], "]"}]}]], "Code",
 CellChangeTimes->{{3.979033719843376*^9, 3.9790337391801653`*^9}, {
  3.9790337899244747`*^9, 3.9790339681155987`*^9}, {3.979034160076756*^9, 
